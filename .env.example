# Kopieer naar .env op de server en vul een echt wachtwoord in.
# Zonder BUS_MONITOR_PASSWORD is er GEEN authenticatie -- verplicht instellen
# zodra de app vanaf het internet bereikbaar is.
BUS_MONITOR_USER=admin
BUS_MONITOR_PASSWORD=verzin-hier-een-sterk-wachtwoord

# Optioneel: een tweede account (bv. een read-only kijker).
#BUS_MONITOR_USER2=Reader
#BUS_MONITOR_PASSWORD2=verzin-hier-een-sterk-wachtwoord

# NS Reisinformatie API-sleutel (apiportal.ns.nl), voor storingen op het
# spoor binnen de provincie Utrecht (zie app/ns_rail_alerts.py). Zonder deze
# key wordt die databron stilzwijgend overgeslagen -- de rest van de app
# blijft gewoon werken.
NS_API_KEY=vul-hier-je-ns-api-key-in
