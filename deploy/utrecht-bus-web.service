[Unit]
Description=Utrecht bus monitor - webserver (gunicorn)
After=network.target utrecht-bus-collector.service

[Service]
Type=simple
User=utrechtbus
WorkingDirectory=/opt/utrecht-bus-monitor
# utrechtbus is een systeem-account zonder eigen homedir (useradd -r); zonder
# expliciete HOME probeert gunicorn dingen weg te schrijven naar het
# niet-bestaande/niet-schrijfbare /home/utrechtbus ("Control server error:
# Permission denied"). /opt/utrecht-bus-monitor is al van utrechtbus, dus
# die kan hier gewoon in schrijven.
Environment=HOME=/opt/utrecht-bus-monitor
EnvironmentFile=-/opt/utrecht-bus-monitor/.env
# --max-requests(-jitter): herstart een worker na ~950-1050 requests, zodat
# geleidelijke geheugengroei (fragmentatie e.d.) periodiek wordt weggegooid
# i.p.v. onbeperkt op te bouwen -- vangnet bovenop de gc.freeze()-fix in
# app/wsgi.py, niet een vervanging ervan. De jitter voorkomt dat beide
# workers precies gelijktijdig herstarten.
ExecStart=/opt/utrecht-bus-monitor/venv/bin/gunicorn --preload -w 2 --timeout 120 --max-requests 1000 --max-requests-jitter 100 -b 127.0.0.1:5151 app.wsgi:app
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
